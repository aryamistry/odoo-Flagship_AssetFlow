{
  "name": "@assetflow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.prisma.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.prisma.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "format": "prettier --write src prisma"
  },
  "dependencies": {
    "@assetflow/contracts": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "express": "5.2.1",
    "express-rate-limit": "8.1.0",
    "helmet": "8.1.0",
    "pg": "8.16.3",
    "pino": "9.9.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.9",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/node": "24.3.0",
    "@types/pg": "8.15.5",
    "prettier": "3.6.2",
    "prisma": "7.8.0",
    "supertest": "7.1.4",
    "@types/supertest": "6.0.3",
    "tsx": "4.20.5",
    "vitest": "4.1.0"
  }
}
